NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/medresearch

# JWT (auth scaffold)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173

# LLM (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.1
LLM_NUM_CTX=8192
LLM_TIMEOUT_MS=120000
EMBED_TIMEOUT_MS=15000

# External research APIs (optional but recommended for higher rate limits)
NCBI_API_KEY=
OPENALEX_MAILTO=

# Cache TTLs
CACHE_TTL_HOURS_PUBS=6
CACHE_TTL_HOURS_TRIALS=24
CACHE_TTL_DAYS_EMBEDDINGS=30

# Ranking
RANKING_TOPK=20
RANKING_TOPK_TRIALS=5
MIN_CORPUS_SIZE=20

# Rate limiting
RATE_LIMIT_PER_MIN=30

# Retrieval ceilings
OPENALEX_MAX_RESULTS=200
PUBMED_MAX_RESULTS=200
CT_MAX_RESULTS=100
